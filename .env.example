DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here

# Optional: uncomment this only when using `npm run deploy:guild` for development.
# DISCORD_GUILD_ID=your_test_server_id_here

# Optional: override where per-server anti-spam settings are stored.
# SPAM_BOT_DATA_FILE=data/guilds.json

# Recommended for hosting: persist all bot and dashboard state in PostgreSQL.
# DATABASE_URL=postgresql://user:password@host:5432/database

# Optional: enable the local web admin dashboard.
# DASHBOARD_PASSWORD=choose_a_strong_password
# DASHBOARD_PORT=3000
# If port 3000 is already occupied, use another free port such as 3001.
# On Render, use 0.0.0.0 (this is selected automatically when Render provides PORT).
# DASHBOARD_HOST=127.0.0.1
